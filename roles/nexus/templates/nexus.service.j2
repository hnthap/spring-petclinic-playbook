[Unit]
Description=Sonatype Nexus Repository Manager
After=network.target

[Service]
Type=forking
User={{ nexus_user }}
Group={{ nexus_user }}
LimitNOFILE=65536
ExecStart={{ nexus_home }}/bin/nexus start
ExecStop={{ nexus_home }}/bin/nexus stop
Restart=on-failure

[Install]
WantedBy=multi-user.target
